    <CheatEntry>
      <ID>65</ID>
      <Description>"Fix bugs related to test character"</Description>
      <Options moManualExpandCollapse="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1" moAllowManualCollapseAndExpand="1"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>64</ID>
          <Description>"Fix Dunlins not spawning bug in Seg4 Sector 2 (test character)"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>// Fix Dunlins not spawning bug in Segment 4 Sector 2 (for test character)
[enable]
alloc(newmem,2048)
label(returnhere)
label(originalcode)
label(exit)
newmem:
mov eax,[HS_e.exe+8A9A24]
cmp eax,04
jne exit
mov eax,02

originalcode:

exit:
jmp returnhere

"HS_e.exe"+EF34F:
jmp newmem
returnhere:
[disable]
</AssemblerScript>
        </CheatEntry>
      </CheatEntries>
    </CheatEntry>
