addZeroToTimerDecimals:
cmp byte ptr [timerDecimals],0A
jl addZeroToTimerDecimals_timerDecimalsUnder10
jmp addZeroToTimerDecimals_timerDecimalsNotUnder10
addZeroToTimerDecimals_timerDecimalsUnder10:
mov ecx,[ebp-00000100]
lea eax,[ebp-000000FC]
mov edx,stringDotZero+4
call HS_e.exe+5730
jmp addZeroToTimerDecimals_timerDecimalsNotUnder10_after
