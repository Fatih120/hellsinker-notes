loadMultiStageReplay_Stage1Timer: // Reset the time record to that of stage 1
call HS_e.exe+301C
push ecx
mov ecx,[esi-08] // [esi-08] is the slot ID
mov eax,[esi] // [esi] is the currently loaded stage timer
mov [multiStageRep_timer+ecx*4],eax
// By the same occasion, also keep in memory the loadout number used in each replay
mov eax,[esi+18] // [esi+18] is the loadout used during the run
mov byte ptr [multiStageRep_loadout+ecx],al
pop ecx
jmp HS_e.exe+C5F63

loadMultiStageReplay_Stage2Timer:
call HS_e.exe+301C
call loadMultiStageReplay_StageAfter1Timer_call
jmp HS_e.exe+C5F7D

