lea eax,[ebp-000000FC]
mov edx,stringTimerSeconds+4
call HS_e.exe+5730
addZeroToTimerDecimals_timerDecimalsNotUnder10_after:
ret

setTimerDecimals:
mov edx,0
mov ecx,64
imul ecx
mov edx,0
mov ecx,3C
idiv ecx
mov edx,0
mov ecx,64
idiv ecx
mov byte ptr [timerDecimals],dl
ret

getNumberOfDigits: // number of digits -> [counter]
push eax
mov [counter],00
getNumberOfDigits_loop:
inc [counter]
mov edx,0
mov ecx,0a
idiv ecx
test eax,eax
jg getNumberOfDigits_loop
pop eax
ret

drawTimerIfSPBT:
push 00
push 41000000
// before this line is original code
// set position
push 441BC000
push 42D40000
// draw
mov eax,timeWhenSpiritBT
call drawBreakthroughTimer
jmp HS_e.exe+BD920

drawTimerIfKLBT:
push 00
push 41000000
// before this line is original code
// set position
push 441BC000
push 433A0000
// draw
mov eax,timeWhenKillBT
call drawBreakthroughTimer
jmp HS_e.exe+BE7E9

drawBreakthroughTimer:
mov [counter2],00
mov eax,[eax]
mov ebx,64 // *100
imul ebx
mov ebx,3C // /60
mov edx,00
idiv ebx
drawBreakthroughTimer_digits_loop:
cmp [counter2],02
jne drawBreakthroughTimer_digits_loop_digit
drawBreakthroughTimer_digits_loop_decimalPoint:
mov eax,E
jmp drawBreakthroughTimer_digits_loop_digit_after
drawBreakthroughTimer_digits_loop_digit:
//divide
mov ebx,0A // /10
mov edx,00
idiv ebx
mov [counter],eax
mov eax,edx
add eax,10
drawBreakthroughTimer_digits_loop_digit_after:

//draw
push [esp+8]
push [esp+8]
mov ecx,FF7BC2FD
call drawWhiteChar
//offset next character 8 pixels left

push -08
fild [esp]
fadd [esp+C]
fstp [esp+C]
pop eax

mov eax,[counter]
//loop (if 4th digit or after & remainder)
inc [counter2]
cmp [counter2],04
jl drawBreakthroughTimer_digits_loop
test eax,eax
jne drawBreakthroughTimer_digits_loop

mov ebx,[esp]
add esp,C
jmp ebx

drawWhiteChar:
push eax
mov eax,[esp+4]
mov [jumpTo],eax
pop eax
mov [esp-4],0100
mov [esp-8],00
mov [esp-C],0108
mov [esp-10],08

// add X sprite rect coords
mov ebx,eax
and eax,07 // modulo 8
shl eax,3 // multiply by 8
mov [float1],eax
fild [float1]
fiadd [esp-4]
fstp [esp-4]
fild [float1]
fiadd [esp-C]
fstp [esp-C]

// add Y sprite rect coords
mov eax,ebx
shr eax,3 // divide by 8
shl eax,3 // multiply by 8
mov [float1],eax
fild [float1]
fiadd [esp-8]
fstp [esp-8]
fild [float1]
fiadd [esp-10]
fstp [esp-10]

add esp,-10
push [esp+18] // push X
push [esp+18] // push Y
push 3F800000
push 3F800000
push 00
push 00
push 0000007C
mov eax,[HS_e.exe+3CBEEC]
mov eax,[eax+000003DC]
mov edx,[HS_e.exe+678588]
call HS_e.exe+84AD8
add esp,0C // Pop 2 values without storing them
jmp [jumpTo]

convert1newmem:
// additional code
cmp word ptr [bulletcount],00
je convert1newmem_original
mov word ptr [cancelledcount],$0000
mov word ptr [convertedcount],$0000
mov byte ptr [bltCancelFlag],$01
convert1newmem_original: // original code
xor eax,eax
mov [ebp-30],eax
jmp HS_e.exe+35584D
convert1newmem2:
// additional code
inc word ptr [cancelledcount]
// original code
mov eax,[ebp-00000114]
mov byte ptr [eax],00
jmp HS_e.exe+35586B
convert1End_newmem:
mov eax,[ebp-000000E0]
mov byte ptr [bltCancelFlag],$00
jmp HS_e.exe+3558BA

convert2newmem:
// additional code
cmp word ptr [bulletcount],00
je convert2newmem_original
mov word ptr [cancelledcount],$0000
mov word ptr [convertedcount],$0000
mov byte ptr [bltCancelFlag],$01
convert2newmem_original: // original code
push ebp
mov ebp,esp
push ebx
push esi
jmp HS_e.exe+BC265
convert2newmem2:
// additional code
inc word ptr [cancelledcount]
// original code
push 00
push 00
mov ecx,[ebx+50]
jmp HS_e.exe+BC292
convert2End_newmem:
jne HS_e.exe+BC272
pop edi
pop esi
pop ebx
mov byte ptr [bltCancelFlag],$00
jmp HS_e.exe+BC2A8

itemgen1_newmem:
cmp byte ptr [bltCancelFlag],00
