jmp HS_e.exe+C6055

loadMultiStageReplay_StageAfter1Timer_call: // Add current stage time record to loaded replay time record
// Check if Segment number is not -1 (meaning that there's no stage played, solving a FSO replay play time display bug)
mov eax,[esi+04] // [esi+04] is the stage ID
test eax,eax
js loadMultiStageReplay_StageAfter1Timer_call_after // Jump if Segment number is -1 (or negative)
push ecx
mov ecx,[esi-08] // [esi-08] is the slot ID
mov eax,[multiStageRep_timer+ecx*4]
add eax,[esi] // Adds current stage timer to total game clear time
mov [multiStageRep_timer+ecx*4],eax
pop ecx
loadMultiStageReplay_StageAfter1Timer_call_after:
ret

