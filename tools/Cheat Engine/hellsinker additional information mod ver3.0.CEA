replayMenu_displayLoadout:
mov eax,esi
shl eax,04
add eax,[replayMenu_displayLoadout_localVariables]
add eax,edi
mov [ebp-0002686C],eax
fild dword ptr [ebp-0002686C]
fstp dword ptr [ebp-0002686C]
mov eax,[ebp-0002686C]
mov [replayMenu_displayLoadout_localVariables+18],eax // Y coordinate for inserting the loadout in replay menus
mov eax,[HS_e.exe+8A9A24]
lea eax,[eax+eax*4]
cmp byte ptr [ebx+eax*4],00
je replayMenu_displayLoadout_end
mov eax,esi
imul eax,[HS_e.exe+8A9A24],00000ABE
mov edx,[ebp-000000FC]
cmp [ebp-28],00
jl replayMenu_displayLoadout_setEAX_MultiStage
mov eax,[edx+eax*8+18]
jmp replayMenu_displayLoadout_deadOrKag
replayMenu_displayLoadout_setEAX_MultiStage:
mov eax,00000000
mov al,byte ptr [multiStageRep_loadout+esi]
replayMenu_displayLoadout_deadOrKag:
cmp [HS_e.exe+8A9A24],00
je replayMenu_displayLoadout_Deadliar
cmp [HS_e.exe+8A9A24],03
je replayMenu_displayLoadout_Kagura
jmp replayMenu_displayLoadout_end
replayMenu_displayLoadout_Deadliar: // Show Deadliar's Misteltoe loadout
push 40778000
push 00
fld [replayMenu_displayLoadout_localVariables+18]
add esp,-08
fstp qword ptr [esp] // Doing this so that the loadout texts don't get exponentially far from each other
push 3F800000
push 3F800000
lea edx,[replayMenu_displayLoadout_stringReferences+eax*4]
mov edx,[edx]
lea edx,[edx+4]
mov eax,FF00FFC0
call HS_e.exe+C42E0 // Print text
jmp replayMenu_displayLoadout_end
replayMenu_displayLoadout_Kagura: // Display Kagura's loadout kanji name for each replay
imul eax,10
mov [replayMenu_displayLoadout_localVariables+C],eax
push 432C0000 // 172.00
fld [replayMenu_displayLoadout_localVariables+4] // Coordinates of sprite top
fiadd [replayMenu_displayLoadout_localVariables+C]
fstp [replayMenu_displayLoadout_localVariables+10] // Stores the floating point value to push it on the stack
push [replayMenu_displayLoadout_localVariables+10]
push 43800000 // 256.00
fld [replayMenu_displayLoadout_localVariables+8] // Coordinates of sprite bottom
fiadd [replayMenu_displayLoadout_localVariables+C]
fstp [replayMenu_displayLoadout_localVariables+10]
push [replayMenu_displayLoadout_localVariables+10]
push 43D00000 // 416
push [replayMenu_displayLoadout_localVariables+18]
push 3F800000
push 3F800000
push 00
push 00
push 000000A0
mov eax,[HS_e.exe+3CBEEC]
mov eax,[eax+000003DC]
or ecx,-01
mov edx,[HS_e.exe+6785D4]
call HS_e.exe+84AD8
replayMenu_displayLoadout_end:
inc esi
add [ebp-000000FC],0000044C
jmp HS_e.exe+3716D4

resetExtendAndDeathCount:
mov [HS_e.exe+678490],eax
mov [totalTimer],eax
mov [deathCount],eax
mov byte ptr [extendCount],al
ret

incrementExtendCount:
inc byte ptr [extendCount]
mov eax,[HS_e.exe+6821F4]
jmp HS_e.exe+34BE3D

incrementExtendCount_Revive:
inc [HS_e.exe+6821F4]
inc byte ptr [extendCount]
jmp HS_e.exe+353283

incrementExtendCount_SPBT: // Spirit Breakthrough
mov byte ptr [HS_e.exe+6784AC],01
inc byte ptr [extendCount]
push eax
mov eax,[totalTimer]
mov [timeWhenSpiritBT],eax
pop eax
jmp HS_e.exe+34C0F5

incrementExtendCount_KLBT: // Kill Breakthrough
mov byte ptr [HS_e.exe+6784AD],01
inc byte ptr [extendCount]
push eax
mov eax,[totalTimer]
mov [timeWhenKillBT],eax
pop eax
jmp HS_e.exe+34C380

incrementDeathCount: // Increment death count when player loses a life
dec [HS_e.exe+6821F4]
inc byte ptr [deathCount]
ret

manageTime: // Manage total time
inc [mainTimer]
inc [totalTimer]
ret

