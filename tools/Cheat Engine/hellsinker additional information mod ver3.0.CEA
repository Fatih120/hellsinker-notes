// Hellsinker. additional information mod ver. 3.0
// by Beetle-Omiwatari
// Displays additional information on the HUD such as the number of bullets, enemies, items, etc...
// Displays:
// • Number of bullets onscreen
// • Number of enemies
// • Number of items
// • Number of Token items
// • Number of Ingots
// • Number of cancelled bullets during the last bullet cancel event
// • Number of converted bullets (in other words, the number of items generated during the last bullet cancel event)
// • Number of crystals collected in Shrine of Farewell (added in version 1.1)
// • Two fractional digits added to the TIMER for a more precise time display (added in version 2.0)
// • TIMER in frames (added in version 2.0)
// • Stage clear time in the LAST RECORDS tab in load/save replay menus (added in version 2.0)
// • Loadout used (for Deadliar and Kagura) in load/save replay menus, next to Bootleg Ghost (added in version 2.0)
// • Number of Extends and Immortality bonuses during play (added in version 2.0)
// • Number of player bullets (added in version 3.0)
// • Number of deaths (added in version 3.0)
// • Total time (added in version 3.0)
// • Time between the beginning of the play and Spirit and Kill Breakthroughs (added in version 3.0)

alloc(newmem,16384)
label(returnhere)
label(originalcode)
label(exit)
define(bulletcount,newmem+$3C00)
define(prayercount,newmem+$3C02)
define(totalitemcount,newmem+$3C04)
define(tokenitemcount,newmem+$3C06)
define(ingotcount,newmem+$3C08)
define(cancelledcount,newmem+$3C0A)
define(convertedcount,newmem+$3C0C)
define(crystalcount,newmem+$3C0E)
define(extendCount,newmem+$3C10)
define(immortalityCount,$00A78494)
define(deathCount,newmem+$3C11)
define(damageCount,HS_e.exe+678504)
define(playerBulletCount,newmem+$3C14)
define(bltCancelFlag,newmem+$3C18)
define(nonZeroDigitFlag,newmem+$3C18)
define(timerDecimals,newmem+$3C19)
define(timerStrPos,newmem+$3C1A)
define(counter,newmem+$3C1E)
define(counter2,newmem+$3C22)
define(lastRecordTime,newmem+$3C26)
define(float1,newmem+$3C2A)
define(float2,newmem+$3C2E)
define(repLR_timeChara,newmem+$3C36)
define(repLR_timeCharaEnd,newmem+$3C3E)
define(totalTimer,newmem+$3C50)
define(timeWhenSpiritBT,newmem+$3C54)
define(timeWhenKillBT,newmem+$3C58)
define(jumpTo,newmem+$3CE0) // Reserved to some routines
define(multiStageRep_timer,newmem+$3D00) // $3D00~3D4C (up to 20 replays)
define(multiStageRep_loadout,newmem+$3E00) // $3E00~3E13 (up to 20 replays)
define(bulletArrayLocation,$00B96414)
define(prayerArrayLocation,$00B2C414)
define(itemArrayLocation,$0078BE8C)
define(playerBulletArrayLocation,$00A83400)
define(mainTimer,HS_e.exe+3CC738)

newmem: //this is allocated memory, you have read,write,execute access
resetCounters:
mov word ptr [bulletcount],$0000
mov word ptr [prayercount],$0000
mov word ptr [totalitemcount],$0000
mov word ptr [tokenitemcount],$0000
mov word ptr [ingotcount],$0000
mov word ptr [playerBulletCount],$0000
cmp [HS_e.exe+3CC73C],01 // When starting playing, reset cancel and convert counters to 0
jne countObjects
resetCancelledAtStart:
mov word ptr [cancelledcount],$0000
mov word ptr [convertedcount],$0000
mov word ptr [crystalcount],$0000
countObjects:
mov esi,00000280 // Prayer bullet array can store up to 640 objects
countBulletsLoop:
dec esi
mov eax,000004C8 // The start address of each object is separated by 0x4C8 bytes.
imul eax,esi
add eax,bulletArrayLocation
cmp byte ptr [eax],00
je afterCountingBullet
inc word ptr [bulletcount]
afterCountingBullet:
cmp esi,00
jne countBulletsLoop
mov esi,00000100 // Prayer array can store up to 256 objects
countPrayersLoop:
dec esi
mov eax,00000690
imul eax,esi
add eax,prayerArrayLocation
cmp byte ptr [eax+02],00
je afterCountingPrayer
inc word ptr [prayercount]
afterCountingPrayer:
cmp esi,00
jne countPrayersLoop
mov esi,00000200 // Item array can store up to 512 objects
countItemsLoop:
dec esi
mov eax,0000008C
imul eax,esi
add eax,[itemArrayLocation]
cmp byte ptr [eax],00
je afterCountingItem
inc word ptr [totalitemcount]
cmp byte ptr [eax+10],01 // Count the number of LUNA crystals
je countTokenItem
cmp byte ptr [eax+10],04 // Count the number of Ingots
je countIngot
cmp byte ptr [eax+10],07 // Count the number of TERRA tokens
je countTokenItem
cmp byte ptr [eax+10],0A // Count the number of bullet cancel LUNA items
je countTokenItem
cmp byte ptr [eax+10],0D // Count the number of LUNA droplets
je countTokenItem
jmp afterCountingItem
countTokenItem:
inc word ptr [tokenitemcount]
jmp afterCountingItem
countIngot:
inc word ptr [ingotcount]
afterCountingItem:
cmp esi,00
jne countItemsLoop
countPlayerBullets:
mov esi,00000100 // Player bullet array can store up to 256 objects
countPlayerBulletsLoop:
dec esi
mov eax,000004C8 // The start address of each object is separated by 0x4C8 bytes.
imul eax,esi
add eax,playerBulletArrayLocation
cmp byte ptr [eax],00
je afterCountingPlayerBullets
inc word ptr [playerBulletCount]
afterCountingPlayerBullets:
cmp esi,00
jne countPlayerBulletsLoop

