collectCrystal_newmem:
add [HS_e.exe+6784E4],eax
inc word ptr [crystalcount]
jmp HS_e.exe+353162

displayTime_replayLastRecords_left:
call HS_e.exe+C3F00
mov eax,[ebp-6C]
add eax,000000A0
mov [ebp-0002686C],eax
fild dword ptr [ebp-0002686C]
add esp,-08
fstp qword ptr [esp]
wait
lea eax,[edi+00000170]
mov [ebp-00026884],eax
fild dword ptr [ebp-00026884]
add esp,-08
fstp qword ptr [esp]
wait
push 3F800000
push 3F800000
mov eax,stringTimeLastRecords+4
call HS_e.exe+C3F00
jmp HS_e.exe+3733AC

displayTime_replayLastRecords_right:
call HS_e.exe+84AD8
cmp [ebp-28],-2
je displayTime_replayLastRecords_right_getLastRecordTime_MultiStage // Load time for FSO replays
cmp [ebp-28],-1
je displayTime_replayLastRecords_right_getLastRecordTime_MultiStage // Load time for Short Mission replays
// For one-stage replays (Segment Location/EX1/EX2)
imul eax,[ebp-70],00000113
imul edx,[HS_e.exe+8A9A24],00000ABE
lea edx,[ebp+edx*8-00020518]
mov eax,[edx+eax*4]
mov [lastRecordTime],eax
jmp displayTime_replayLastRecords_right_afterGettingLastRecordTime
// For multi-stage replays (FSO/Short)
displayTime_replayLastRecords_right_getLastRecordTime_MultiStage:
mov eax,[ebp-70]
mov eax,[multiStageRep_timer+eax*4]
mov [lastRecordTime],eax
jmp displayTime_replayLastRecords_right_afterGettingLastRecordTime

displayTime_replayLastRecords_right_afterGettingLastRecordTime:
mov ecx,64
imul ecx
mov ecx,3C
idiv ecx
mov [lastRecordTime],eax
// Store the digits
mov [counter],09
mov eax,[lastRecordTime]
mov [counter2],repLR_timeCharaEnd
displayTime_replayLastRecords_right_storeTimeDigits_loop:
dec [counter]
mov ebx,00
mov ecx,0A
mov edx,00
idiv ecx // Divide eax by 10
mov bl,dl // Set each digit to the modulo
inc bl // Increment BL, otherwise 1 will be displayed as 0, 2 as 1, 3 as 2, etc...
displayTime_replayLastRecords_right_loop_blankZero:
mov edx,[counter2]
mov byte ptr [edx],bl // Load each digit
dec [counter2]
cmp [counter],00
jne displayTime_replayLastRecords_right_storeTimeDigits_loop
mov [counter],00
mov byte ptr [nonZeroDigitFlag],00
displayTime_replayLastRecords_right_displayTimeDigits_loop:
// Display the digits
mov ebx,[counter]
mov ecx,00
mov cl,byte ptr [repLR_timeChara+ebx]
cmp cl,01 // Check if digit is yellow 0
je displayTime_replayLastRecords_right_displayTimeDigits_loop_setNZDFlag_after
mov byte ptr [nonZeroDigitFlag],01
displayTime_replayLastRecords_right_displayTimeDigits_loop_setNZDFlag_after:
cmp byte ptr [nonZeroDigitFlag],00
jne displayTime_replayLastRecords_right_displayTimeDigits_loop_setToBlankZero_after
mov cl,00
displayTime_replayLastRecords_right_displayTimeDigits_loop_setToBlankZero_after:
imul ecx,8
mov [float1],ecx
fild [float1]
fstp [float1]
push [float1]
push 42400000
mov [float2],41000000
fld [float1]
fadd [float2]
fstp [float1]
push [float1]
push 42800000
lea eax,[148+ebx*8] // 148 is the initial X position, *8 is the character spacing
mov [float1],eax
fild [float1]
fstp [float1]
push [float1]
lea eax,[edi+170] // 148 is the initial X position, *8 is the character spacing
mov [float1],eax
fild [float1]
fstp [float1]
push [float1]
push 3F800000
push 3F800000
push 00
